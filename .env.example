# ============================================================
# telegram-claude-bot — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ── Telegram Bot Tokens ─────────────────────────────────────
# One token per persona bot — get from @BotFather
TELEGRAM_BOT_TOKEN_ADMIN=your-admin-bot-token-here
TELEGRAM_BOT_TOKEN_BOT1=your-bot1-token-here
TELEGRAM_BOT_TOKEN_BOT2=your-bot2-token-here
# Add more as needed: TELEGRAM_BOT_TOKEN_<ID>=...

# ── Admin Config ────────────────────────────────────────────
# Your personal Telegram user ID (get from @userinfobot)
ADMIN_USER_ID=YOUR_TELEGRAM_USER_ID

# Main working group chat ID (negative number for groups)
GROUP_ID=YOUR_GROUP_CHAT_ID

# Personal group chat ID
PERSONAL_GROUP_ID=YOUR_PERSONAL_GROUP_CHAT_ID

# Team group chat ID (optional)
TEAM_E_GROUP_ID=YOUR_TEAM_GROUP_CHAT_ID

# Thread ID for auto-healer alerts within PERSONAL_GROUP_ID
HEALER_THREAD_ID=1

# ── Primary LLM (Kimi / OpenAI-compatible) ──────────────────
KIMI_API_KEY=your-kimi-api-key-here

# ── Fallback LLM Chain ──────────────────────────────────────
# The bot auto-falls back through these in order
CEREBRAS_API_KEY=your-cerebras-api-key-here
DEEPSEEK_API_KEY=your-deepseek-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# ── Optional LLM Providers ──────────────────────────────────
MINIMAX_API_KEY=your-minimax-api-key-here
GROQ_API_KEY=your-groq-api-key-here
OPENAI_API_KEY=your-openai-api-key-here     # used for critic/reviewer roles

# ── X / Twitter (for X curation feature) ───────────────────
TELEGRAM_BOT_TOKEN_TWITTER=your-twitter-bot-token-here
TWITTER_USERNAME=your_twitter_username
TWITTER_EMAIL=your_twitter_email@example.com
TWITTER_PASSWORD=your_twitter_password
TWITTER_TOTP_SECRET=your_totp_secret        # optional, only if 2FA enabled
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
TWITTER_ACCESS_TOKEN=your-twitter-access-token
TWITTER_ACCESS_SECRET=your-twitter-access-secret
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret

# ── Crypto (for crypto digest feature) ──────────────────────
COINGECKO_API_KEY=your-coingecko-api-key
CMC_API_KEY=your-coinmarketcap-api-key
CRYPTORANK_API_KEY=your-cryptorank-api-key

# ── Web Scraping ─────────────────────────────────────────────
FIRECRAWL_API_KEY=your-firecrawl-api-key
XCRAWL_API_KEY=your-xcrawl-api-key

# ── VPS / Infrastructure ─────────────────────────────────────
VPS_HOST=your.vps.ip.address
VPS_USER=your_vps_username

# ── Telethon (optional — for reading TG as a user account) ──
# Only needed if using x_curator.py with Telethon scraping
TELETHON_API_ID=your-telethon-api-id
TELETHON_API_HASH=your-telethon-api-hash

# ── Auto-reply ───────────────────────────────────────────────
# Comma-separated Telegram usernames that trigger auto-reply testing
AUTO_REPLY_TEST_USERS=friend_username

# ── Gmail (optional — for Gmail digest feature) ──────────────
# Requires OAuth setup — see docs/gmail_setup.md
# gmail_credentials.json and gmail_token.json are stored separately
