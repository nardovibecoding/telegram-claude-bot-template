PathModified=/home/YOUR_USER/YOUR_BOT_DIR/admin_bot/cognitive.py
PathModified=/home/YOUR_USER/YOUR_BOT_DIR/admin_bot/chat.py
PathModified=/home/YOUR_USER/YOUR_BOT_DIR/admin_bot/config.py
PathModified=/home/YOUR_USER/YOUR_BOT_DIR/admin_bot/domains.py
PathModified=/home/YOUR_USER/YOUR_BOT_DIR/admin_bot/__main__.py
PathModified=/home/YOUR_USER/YOUR_BOT_DIR/admin_bot.py
Unit=adminbot-restart.service

[Install]
WantedBy=default.target
